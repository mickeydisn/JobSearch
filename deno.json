{
  "name": "@jobsearch/app",
  "version": "1.0.0",
  "exports": "./web_service/server.ts",
  "tasks": {
    "generate:page": "deno run --allow-read --allow-write tasks/generate_page.ts",
    "dev": "deno run --allow-all web_service/server.ts",
    "check": "deno check web_service/server.ts"
  },
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    
    "compromise": "npm:compromise@^14.14.0",
    "langchain": "npm:langchain@^1.2.7",
    "langchain/openai": "npm:@langchain/openai@^1.2.2",
    "deepagents": "npm:deepagents@^1.4.2",
    "zod": "npm:zod@^3.23.8",
    "marked": "npm:marked@^17.0.1"
  },
  "compilerOptions": {
    "lib": ["deno.window"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
